{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LinguaLive",
  "version": "0.2.0",
  "identifier": "com.lingua-live.desktop",
  "build": {
    "beforeDevCommand": "npm run dev -w @lingua-live/app",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build -w @lingua-live/core && npm run build -w @lingua-live/app",
    "frontendDist": "../../app/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LinguaLive",
        "width": 1200,
        "height": 820,
        "resizable": true,
        "backgroundColor": "#0b1020"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "LinguaLive",
    "copyright": "Copyright © 2026 LinguaLive",
    "category": "Productivity",
    "shortDescription": "AI simultaneous interpretation assistant",
    "longDescription": "Real-time Chinese subtitles from English or other source audio using streaming ASR, DeepSeek translation, self-correction, and optional TTS.",
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
